OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_VOICE_MODEL=llama3.2:1b

DATABASE_URL=postgresql+asyncpg://ava:ava@localhost:5432/ava

# STT: twilio (Real-Time Transcriptions) or whisper (local faster-whisper)
STT_PROVIDER=twilio
TWILIO_TRANSCRIPTION_ENGINE=deepgram
TWILIO_TRANSCRIPTION_SPEECH_MODEL=nova-2
TWILIO_TRANSCRIPTION_HINTS=Done, okay, yes, IndusDirect, customer ID, user ID, password, OTP, login
TWILIO_TRANSCRIPTION_LANGUAGE=en-US

WHISPER_MODEL_SIZE=base
WHISPER_VOICE_MODEL_SIZE=base
# Default after ./scripts/setup-local.sh (project models/ directory)
PIPER_VOICE_PATH=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Required for phone calls via ngrok: your public HTTPS URL (no trailing slash)
PUBLIC_BASE_URL=
